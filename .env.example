ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
EMAIL_ADDRESS=your_gmail_address
EMAIL_APP_PASSWORD=your_gmail_app_password
EMAIL_RECIPIENT=default_recipient_email

# Secret pour signer les cookies de session Chainlit (sinon regenere a chaque restart)
# Genere une valeur unique : python -c "import secrets; print(secrets.token_urlsafe(32))"
CHAINLIT_AUTH_SECRET=generate_via_python_secrets_token_urlsafe_32

# Comptes utilisateurs pour l'authentification Chainlit (JSON serialise sur une ligne)
# Remplace la liste hardcodee dans app.py pour ne pas exposer les emails dans le repo public
# Exemple de format :
# USER_ACCOUNTS_JSON={"user1@mail.com":{"password":"pwd","name":"User1","role":"admin"},"user2@mail.com":{"password":"pwd","name":"User2","role":"user"}}
USER_ACCOUNTS_JSON={"demo@saearch.ai":{"password":"demo","name":"Demo","role":"user"}}

# Repertoire d'emails equipe (pour l'outil send_bulk_email et resolution de noms)
# Cle = prenom en minuscule, valeur = email
# Exemple :
# TEAM_DIRECTORY_JSON={"prenom1":"email1@mail.com","prenom2":"email2@mail.com"}
TEAM_DIRECTORY_JSON={}

# Destinataires du teaser soutenance (scripts/teaser_vendredi.py)
# JSON : cle = "Nom Prenom" (tel qu'affiche dans le mail), valeur = email
# Exemple :
# TEASER_RECIPIENTS_JSON={"Nom1 Prenom1":"email1@mail.com","Nom2 Prenom2":"email2@mail.com"}
TEASER_RECIPIENTS_JSON={}

# Signature equipe affichee en pied du teaser (chaine libre, sans email)
# Exemple : TEASER_SIGNATURE="L'équipe SAEARCH : Prénom1 Nom1 • Prénom2 Nom2"
TEASER_SIGNATURE=L'équipe SAEARCH

# ── MLflow tracking ─────────────────────────────────────────────────────────
# Backend au choix (laisser vide = fallback sqlite:///mlflow.db en local) :
#   1. Local SQLite (recommande) : sqlite:///mlflow.db
#   2. Local file store (deprecie 02/2026) : file:./mlruns
#   3. PostgreSQL : postgresql://user:pwd@host:5432/mlflow
#   4. Serveur MLflow distant : http://mlflow.example.com:5000
#   5. Azure ML Workspace (prod, requiert `pip install azureml-mlflow` + `az login`) :
#      azureml://<region>.api.azureml.ms/mlflow/v1.0/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.MachineLearningServices/workspaces/<ws>
#   6. Databricks : databricks
MLFLOW_TRACKING_URI=
# Dossier artefacts (plots, modeles) si separe du backend metadonnees
MLFLOW_ARTIFACT_ROOT=
# Nom de l'experience (override facultatif)
MLFLOW_EXPERIMENT=NB10_train_script
MLFLOW_EXPERIMENT_AGENT=rag-catastrophes-climatiques
# Label d'environnement ajoute comme tag (local / ci / prod)
ENV_LABEL=

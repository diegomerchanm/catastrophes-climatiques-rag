ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
EMAIL_ADDRESS=your_gmail_address
EMAIL_APP_PASSWORD=your_gmail_app_password
EMAIL_RECIPIENT=default_recipient_email

# ── MLflow tracking ─────────────────────────────────────────────────────────
# Backend au choix (laisser vide = fallback sqlite:///mlflow.db en local) :
#   1. Local SQLite (recommande) : sqlite:///mlflow.db
#   2. Local file store (deprecie 02/2026) : file:./mlruns
#   3. PostgreSQL : postgresql://user:pwd@host:5432/mlflow
#   4. Serveur MLflow distant : http://mlflow.example.com:5000
#   5. Azure ML Workspace (prod, requiert `pip install azureml-mlflow` + `az login`) :
#      azureml://<region>.api.azureml.ms/mlflow/v1.0/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.MachineLearningServices/workspaces/<ws>
#   6. Databricks : databricks
MLFLOW_TRACKING_URI=
# Dossier artefacts (plots, modeles) si separe du backend metadonnees
MLFLOW_ARTIFACT_ROOT=
# Nom de l'experience (override facultatif)
MLFLOW_EXPERIMENT=NB10_train_script
MLFLOW_EXPERIMENT_AGENT=rag-catastrophes-climatiques
# Label d'environnement ajoute comme tag (local / ci / prod)
ENV_LABEL=
